<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Reminder.Change_reminder"
             x:Name="Root"
             Title="Create reminder">
    <ScrollView>
        <VerticalStackLayout Spacing="10" BackgroundColor="#D1E7CC" Padding="10">

            <Editor x:Name="MessageEntry"
                    TextColor="Black"
                    Placeholder="Enter message"
                    AutoSize="TextChanges"
                    VerticalOptions="Start" />

            <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                <CheckBox x:Name="SecChangeBox" Color="Black" />
                <Label Text="Use seconds" VerticalOptions="Center" TextColor="Black" />
            </HorizontalStackLayout>

            <Label Text="Next Date\Time(HH-MM:SS)" TextColor="Black" />
            <HorizontalStackLayout>
                <DatePicker x:Name="NextDatePicker" TextColor="Black" />
                <TimePicker x:Name="NextTimePicker" TextColor="Black"></TimePicker>
                <Picker x:Name="NextTimeSecondPicker" WidthRequest="80" TextColor="Black"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                <CheckBox x:Name="IntervalCheck" Color="Black" />
                <Label Text="Enable Interval" VerticalOptions="Center" TextColor="Black" />
            </HorizontalStackLayout>

            <VerticalStackLayout IsEnabled="{Binding Source={x:Reference IntervalCheck}, Path=IsChecked}">

                <Label Text="Interval Time (HH-MM:SS)" TextColor="Black" />
                <HorizontalStackLayout Spacing="8" >

                    <TimePicker x:Name="IntervalTimePicker" />
                    <Picker x:Name="IntervalTimeSecondPicker" WidthRequest="80" />
                </HorizontalStackLayout>

                <Label Text="Interval Duration" TextColor="Black" />
                <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto" ColumnSpacing="8">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="Days" FontSize="Micro" TextColor="Black" />
                        <Entry x:Name="IntervalDaysEntry" Keyboard="Numeric" Placeholder="0" TextColor="Black">
                            <Entry.Triggers>
                                <DataTrigger TargetType="Entry" Value="False">
                                    <Setter Property="IsEnabled" Value="False" />
                                    <Setter Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </Entry.Triggers>
                        </Entry>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="Months" FontSize="Micro"  TextColor="Black"/>
                        <Entry x:Name="IntervalMonthsEntry" Keyboard="Numeric" Placeholder="0" TextColor="Black">
                            <Entry.Triggers>
                                <DataTrigger TargetType="Entry" Value="False">
                                    <Setter Property="IsEnabled" Value="False" />
                                    <Setter Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </Entry.Triggers>
                        </Entry>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" Spacing="4">
                        <Label Text="Years" FontSize="Micro"  TextColor="Black"/>
                        <Entry x:Name="IntervalYearsEntry" Keyboard="Numeric" Placeholder="0" TextColor="Black">
                            <Entry.Triggers>
                                <DataTrigger TargetType="Entry" Value="False">
                                    <Setter Property="IsEnabled" Value="False" />
                                    <Setter Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </Entry.Triggers>
                        </Entry>
                    </VerticalStackLayout>
                </Grid>

                <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                    <CheckBox x:Name="StopCheck"  />
                    <Label Text="Enable Stop" VerticalOptions="Center" TextColor="Black" />
                </HorizontalStackLayout>

                <VerticalStackLayout IsEnabled="{Binding Source={x:Reference StopCheck}, Path=IsChecked}">

                    <Label Text="Stop Date\Time(HH-MM:SS)" TextColor="Black" />
                    <HorizontalStackLayout>

                        <DatePicker x:Name="StopDatePicker" TextColor="Black">
                            <DatePicker.Triggers>
                                <DataTrigger TargetType="DatePicker" Value="False">
                                    <Setter Property="IsEnabled" Value="False" />
                                    <Setter Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </DatePicker.Triggers>
                        </DatePicker>

                        <TimePicker x:Name="StopTimePicker" TextColor="Black" />
                        <Picker x:Name="StopTimeSecondPicker" WidthRequest="80" TextColor="Black"/>

                    </HorizontalStackLayout>
                    
                </VerticalStackLayout>
            </VerticalStackLayout>
            
            <Button Text="Create Remind" Clicked="OnCreateClicked" x:Name="CreateRemindButton" TextColor="Black" />
            <Button Text="Delete Remind" Clicked="OnDeleteClicked" BackgroundColor="Red" x:Name="DeleteRemindButton" IsVisible="False" TextColor="Black" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>